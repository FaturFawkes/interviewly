# ------------------------------
# Docker Compose - Core services
# ------------------------------
POSTGRES_USER=interviewly
POSTGRES_PASSWORD=interviewly
POSTGRES_DB=interviewly

PORT=8080
APP_ENV=docker
DATABASE_URL=postgresql://interviewly:interviewly@postgres:5432/interviewly?sslmode=disable
POSTGRES_MAX_CONNS=10
POSTGRES_MIN_CONNS=1
POSTGRES_MAX_CONN_LIFETIME_MINUTES=30

REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_SECRET=compose-secret
JWT_ISSUER=compose-issuer
# Access token TTL in minutes (default: 60 = 1 hour)
ACCESS_TOKEN_TTL_MINUTES=60
# Refresh token TTL in hours (default: 24 = 1 day; user must re-login after this idle period)
REFRESH_TOKEN_TTL_HOURS=24

# ------------------------------
# OTP Email (SMTP)
# Leave SMTP_HOST empty to use log fallback (OTP printed in backend logs).
# ------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@interviewly.local
SMTP_FROM_NAME=Interviewly
OTP_EXPIRY_MINUTES=10

# ------------------------------
# AI Provider (optional)
# local  : heuristic internal engine
# openai : OpenAI-compatible chat completion API
# ------------------------------
AI_PROVIDER=OpenAI
AI_MODEL=gpt-4o-mini
AI_API_BASE_URL=https://api.openai.com/v1
AI_API_KEY=

# ------------------------------
# Voice Provider (ElevenLabs)
# Required for voice interview mode + realtime agent call screen.
# ------------------------------
VOICE_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_STT_MODEL=scribe_v1
ELEVENLABS_AGENT_ID=
ELEVENLABS_AGENT_BRANCH_ID=
ELEVENLABS_REVIEW_AGENT_ID=

# ------------------------------
# Resume File Storage (Supabase)
# Official S3 protocol (server-side) as documented by Supabase Storage.
# Endpoint format: https://<project-ref>.storage.supabase.co/storage/v1/s3
# Leave ACCESS_KEY/SECRET empty to disable Supabase S3 resume upload.
# ------------------------------
SUPABASE_URL=
SUPABASE_S3_ENDPOINT=
SUPABASE_S3_REGION=us-east-1
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_STORAGE_BUCKET=resumes
SUPABASE_STORAGE_PATH_PREFIX=

# ------------------------------
# Frontend / NextAuth
# ------------------------------
NEXTAUTH_SECRET=compose-nextauth-secret
NEXTAUTH_URL=http://localhost:3000
BACKEND_AUTH_BASE_URL=http://backend:8080

NEXT_PUBLIC_API_BASE_URL=/api-proxy
NEXT_PUBLIC_VOICE_CALL_MAX_SECONDS=900
BACKEND_INTERNAL_URL=http://backend:8080

# Optional local dev fallback token (legacy flow)
NEXT_PUBLIC_DEV_JWT_TOKEN=

# ------------------------------
# OAuth Providers (optional)
# Leave empty if social login is not configured yet.
# ------------------------------
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

AUTH_AZURE_AD_ID=
AUTH_AZURE_AD_SECRET=
AUTH_AZURE_AD_TENANT_ID=

# ------------------------------
# Stripe Payment (for landing page pricing checkout)
# ------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:3000?payment=success
STRIPE_CANCEL_URL=http://localhost:3000?payment=cancel
STRIPE_CURRENCY=idr

# Optional: use Stripe Price IDs (recommended for production).
# If empty, backend falls back to dynamic monthly prices:
# starter=59000, pro=129000, elite=279000 (in smallest currency unit).
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_ELITE_MONTHLY=

# Optional: voice top-up Price IDs (recommended for production).
# If empty, backend falls back to dynamic one-time prices below.
STRIPE_PRICE_VOICE_TOPUP_10=
STRIPE_PRICE_VOICE_TOPUP_30=

# Fallback one-time top-up prices (used when STRIPE_PRICE_VOICE_TOPUP_* is empty).
# Keep in smallest currency unit for STRIPE_CURRENCY.
VOICE_TOPUP_10_AMOUNT_IDR=19000
VOICE_TOPUP_30_AMOUNT_IDR=49000
